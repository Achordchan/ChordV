{
  "name": "chordv",
  "private": true,
  "version": "1.1.6",
  "packageManager": "pnpm@9.15.3",
  "engines": {
    "node": "20.19.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check": "turbo check",
    "lint": "turbo lint",
    "prepare:1panel-bundle": "node ./scripts/prepare-1panel-chordv-bundle.mjs",
    "release:desktop": "bash scripts/release-desktop.sh",
    "setup:mac": "docker compose up -d postgres && pnpm install && pnpm --filter @chordv/api db:generate && pnpm --filter @chordv/api db:push && pnpm --filter @chordv/api db:seed",
    "dev:mac": "pnpm --filter @chordv/desktop tauri:dev",
    "dev:ops": "concurrently -k -n api,admin -c blue,green \"pnpm --filter @chordv/api dev\" \"pnpm --filter @chordv/admin dev -- --host 127.0.0.1\"",
    "dev:api": "pnpm --filter @chordv/api dev",
    "dev:admin": "pnpm --filter @chordv/admin dev",
    "dev:desktop": "pnpm --filter @chordv/desktop dev",
    "prepare:release-storage": "node ./scripts/prepare-release-storage.mjs",
    "deploy:baota": "bash scripts/deploy-baota.sh"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "turbo": "^2.4.2",
    "typescript": "^5.7.3"
  }
}
