generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum UserStatus {
  active
  disabled
}

enum PlanScope {
  personal
  team
}

enum TeamStatus {
  active
  disabled
}

enum TeamMemberRole {
  owner
  member
}

enum SubscriptionState {
  active
  expired
  exhausted
  paused
}

enum SubscriptionSourceAction {
  created
  renewed
  plan_changed
  adjusted
}

enum NodeProbeStatus {
  unknown
  healthy
  degraded
  offline
}

enum MeteringIncidentStatus {
  open
  resolved
}

enum EdgeGatewayStatus {
  online
  offline
  degraded
}

enum XuiPanelStatus {
  online
  offline
  degraded
}

enum NodeSessionLeaseStatus {
  active
  expired
  revoked
  evicted
}

enum SecurityEventType {
  session_evicted
  session_revoked
  relay_open_failed
}

enum AnnouncementLevel {
  info
  warning
  success
}

enum AnnouncementDisplayMode {
  passive
  modal_confirm
  modal_countdown
}

enum ReleasePlatform {
  macos
  windows
  android
  ios
}

enum ReleaseChannel {
  stable
}

enum ReleaseStatus {
  draft
  published
  archived
}

enum ReleaseArtifactType {
  dmg
  app
  exe
  setup_exe
  apk
  ipa
  external
}

enum ReleaseArtifactSource {
  uploaded
  external
}

enum RuntimeComponentArchitecture {
  x64
  arm64
}

enum RuntimeComponentKind {
  xray
  geoip
  geosite
}

enum RuntimeComponentSource {
  uploaded
  github_remote
  custom_remote
}

enum UpdateDeliveryMode {
  desktop_installer_download
  apk_download
  external_download
  none
}

model User {
  id                   String              @id
  email                String              @unique
  displayName          String
  role                 UserRole
  status               UserStatus
  authVersion          Int                 @default(1)
  maxConcurrentSessionsOverride Int?
  passwordHash         String
  lastSeenAt           DateTime
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  subscriptions        Subscription[]
  ownedTeams           Team[]              @relation("TeamOwner")
  teamMemberships      TeamMember[]
  trafficLedgerEntries TrafficLedger[]
  trafficSnapshots     TrafficSnapshot[]
  refreshTokens        RefreshToken[]
  sessionLeases        NodeSessionLease[]
  securityEvents       SecurityEvent[]
  panelClientBindings  PanelClientBinding[]
}

model Plan {
  id             String         @id
  name           String
  scope          PlanScope      @default(personal)
  totalTrafficGb Float
  renewable      Boolean
  maxConcurrentSessions Int      @default(3)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  subscriptions  Subscription[]
}

model Subscription {
  id                 String                   @id
  userId             String?
  teamId             String?
  planId             String
  totalTrafficGb     Float
  usedTrafficGb      Float
  remainingTrafficGb Float
  expireAt           DateTime
  state              SubscriptionState
  renewable          Boolean
  sourceAction       SubscriptionSourceAction @default(created)
  lastSyncedAt       DateTime
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  plan               Plan                     @relation(fields: [planId], references: [id], onDelete: Cascade)
  user               User?                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  team               Team?                    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  trafficLedgerEntries TrafficLedger[]
  trafficSnapshots   TrafficSnapshot[]
  nodeAccesses       SubscriptionNodeAccess[]
  meteringIncidents  MeteringIncident[]
  sessionLeases      NodeSessionLease[]
  securityEvents     SecurityEvent[]
  panelClientBindings PanelClientBinding[]
}

model Team {
  id            String         @id
  name          String
  ownerUserId   String
  status        TeamStatus
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  owner         User           @relation("TeamOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  members       TeamMember[]
  subscriptions Subscription[]
  trafficLedgerEntries TrafficLedger[]
  trafficSnapshots TrafficSnapshot[]
  panelClientBindings PanelClientBinding[]
}

model TeamMember {
  id        String         @id
  teamId    String
  userId    String
  role      TeamMemberRole
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  team      Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@unique([userId])
}

model TrafficLedger {
  id             String       @id
  teamId         String
  userId         String
  subscriptionId String
  nodeId         String?
  usedTrafficGb  Float
  recordedAt     DateTime
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  team           Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  node           Node?        @relation(fields: [nodeId], references: [id], onDelete: SetNull)

  @@index([teamId, subscriptionId, userId, recordedAt])
  @@index([teamId, userId, nodeId, recordedAt])
}

model Node {
  id               String          @id
  name             String
  region           String
  provider         String
  tags             String[]
  recommended      Boolean
  latencyMs        Int
  protocol         String
  security         String
  serverHost       String
  serverPort       Int
  uuid             String
  flow             String
  realityPublicKey String
  shortId          String
  serverName       String
  fingerprint      String
  spiderX          String          @default("/")
  subscriptionUrl  String?
  gatewayStatus    EdgeGatewayStatus @default(offline)
  statsLastSyncedAt DateTime?
  probeStatus      NodeProbeStatus @default(unknown)
  probeLatencyMs   Int?
  probeCheckedAt   DateTime?
  probeError       String?
  panelBaseUrl     String?
  panelApiBasePath String?         @default("/")
  panelUsername    String?
  panelPassword    String?
  panelInboundId   Int?
  panelEnabled     Boolean         @default(false)
  panelStatus      XuiPanelStatus  @default(offline)
  panelLastSyncedAt DateTime?
  panelError       String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  subscriptionAccesses SubscriptionNodeAccess[]
  trafficLedgerEntries TrafficLedger[]
  trafficSnapshots TrafficSnapshot[]
  meteringIncidents MeteringIncident[]
  sessionLeases     NodeSessionLease[]
  securityEvents    SecurityEvent[]
  panelClientBindings PanelClientBinding[]
}

model SubscriptionNodeAccess {
  id             String       @id
  subscriptionId String
  nodeId         String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  node           Node         @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, nodeId])
  @@unique([subscriptionId, nodeId])
}

model MeteringIncident {
  id             String                @id
  subscriptionId String
  nodeId         String
  reason         String
  status         MeteringIncidentStatus @default(open)
  detail         String?
  openedAt       DateTime
  resolvedAt     DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  subscription   Subscription          @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  node           Node                  @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, status, openedAt])
  @@index([nodeId, status, openedAt])
  @@index([subscriptionId, nodeId, reason, status])
}

model TrafficSnapshot {
  id               String       @id
  snapshotKey      String       @unique
  nodeId           String
  subscriptionId   String
  userId           String?
  teamId           String?
  uplinkBytes      BigInt       @default(0)
  downlinkBytes    BigInt       @default(0)
  totalBytes       BigInt       @default(0)
  sampledAt        DateTime
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  node             Node         @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  subscription     Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  user             User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  team             Team?        @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([nodeId, subscriptionId])
}

model RefreshToken {
  id        String   @id
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([userId, revokedAt, createdAt])
}

model NodeSessionLease {
  id             String               @id
  sessionId      String               @unique
  accessMode     String               @default("relay")
  userId         String
  subscriptionId String
  nodeId         String
  xrayUserEmail  String
  xrayUserUuid   String
  status         NodeSessionLeaseStatus @default(active)
  issuedAt       DateTime
  expiresAt      DateTime
  lastHeartbeatAt DateTime
  revokedAt      DateTime?
  revokedReason  String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription   Subscription         @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  node           Node                 @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  securityEvents SecurityEvent[]

  @@index([userId, status, expiresAt])
  @@index([subscriptionId, status, expiresAt])
  @@index([nodeId, status, expiresAt])
}

model SecurityEvent {
  id             String            @id
  type           SecurityEventType
  userId         String?
  subscriptionId String?
  nodeId         String?
  leaseId        String?
  detail         String?
  createdAt      DateTime          @default(now())
  user           User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  subscription   Subscription?     @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  node           Node?             @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  lease          NodeSessionLease? @relation(fields: [leaseId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
  @@index([userId, createdAt])
  @@index([subscriptionId, createdAt])
  @@index([nodeId, createdAt])
}

model PanelClientBinding {
  id               String       @id
  subscriptionId   String
  userId           String?
  teamId           String?
  nodeId           String
  panelClientEmail String
  panelClientId    String
  panelInboundId   Int
  lastUplinkBytes  BigInt       @default(0)
  lastDownlinkBytes BigInt      @default(0)
  lastSyncedAt     DateTime?
  status           String       @default("active")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  subscription     Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  user             User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  team             Team?        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  node             Node         @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, userId, nodeId])
  @@index([subscriptionId, nodeId, status])
  @@index([nodeId, panelClientEmail])
}

model PolicyProfile {
  id              String          @id
  accessMode      String          @default("xui")
  defaultMode     String
  modes           String[]
  ruleVersion     String
  ruleUpdatedAt   DateTime
  dnsProfile      String
  blockAds        Boolean
  chinaDirect     Boolean
  aiServicesProxy Boolean
  currentVersion  String
  minimumVersion  String
  forceUpgrade    Boolean         @default(false)
  changelog       String[]
  downloadUrl     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  strategyGroups  StrategyGroup[]
}

model StrategyGroup {
  id            String        @id
  policyId      String
  name          String
  description   String
  defaultNodeId String
  policy        PolicyProfile @relation(fields: [policyId], references: [id], onDelete: Cascade)
}

model Announcement {
  id              String                  @id
  title           String
  body            String
  level           AnnouncementLevel
  publishedAt     DateTime
  isActive        Boolean                 @default(true)
  displayMode     AnnouncementDisplayMode @default(passive)
  countdownSeconds Int                    @default(0)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
}

model Release {
  id             String         @id
  platform       ReleasePlatform
  channel        ReleaseChannel
  version        String
  displayTitle   String
  releaseNotes   String?
  changelog      String[]
  minimumVersion String
  forceUpgrade   Boolean        @default(false)
  status         ReleaseStatus  @default(draft)
  publishedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  artifacts      ReleaseArtifact[]

  @@unique([platform, channel, version])
  @@index([platform, channel, status, publishedAt])
}

model ReleaseArtifact {
  id            String             @id
  releaseId     String
  source        ReleaseArtifactSource @default(external)
  type          ReleaseArtifactType
  deliveryMode  UpdateDeliveryMode @default(external_download)
  downloadUrl   String
  defaultMirrorPrefix String?
  allowClientMirror Boolean        @default(true)
  fileName      String?
  storedFilePath String?
  fileSizeBytes BigInt?
  fileHash      String?
  isPrimary     Boolean            @default(false)
  isFullPackage Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  release       Release            @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@index([releaseId, isPrimary])
}

model RuntimeComponent {
  id                  String                       @id
  platform            ReleasePlatform
  architecture        RuntimeComponentArchitecture
  kind                RuntimeComponentKind
  source              RuntimeComponentSource      @default(github_remote)
  originUrl           String
  defaultMirrorPrefix String?
  allowClientMirror   Boolean                     @default(true)
  fileName            String
  storedFilePath      String?
  fileSizeBytes       BigInt?
  fileHash            String?
  archiveEntryName    String?
  expectedHash        String?
  enabled             Boolean                     @default(true)
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  failureReports      RuntimeComponentFailureReport[]

  @@unique([platform, architecture, kind])
  @@index([platform, architecture, enabled])
}

model RuntimeComponentFailureReport {
  id           String                       @id
  componentId  String?
  platform     ReleasePlatform
  architecture RuntimeComponentArchitecture
  kind         RuntimeComponentKind
  reason       String
  message      String?
  effectiveUrl String?
  appVersion   String?
  userId       String?
  createdAt    DateTime                     @default(now())
  component    RuntimeComponent?            @relation(fields: [componentId], references: [id], onDelete: SetNull)

  @@index([platform, architecture, createdAt])
  @@index([componentId, createdAt])
}
