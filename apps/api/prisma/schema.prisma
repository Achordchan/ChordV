generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum UserStatus {
  active
  disabled
}

enum PlanScope {
  personal
  team
}

enum TeamStatus {
  active
  disabled
}

enum TeamMemberRole {
  owner
  member
}

enum SubscriptionState {
  active
  expired
  exhausted
  paused
}

enum SubscriptionSourceAction {
  created
  renewed
  plan_changed
  adjusted
}

enum NodeProbeStatus {
  unknown
  healthy
  degraded
  offline
}

enum AnnouncementLevel {
  info
  warning
  success
}

enum AnnouncementDisplayMode {
  passive
  modal_confirm
  modal_countdown
}

model User {
  id                   String              @id
  email                String              @unique
  displayName          String
  role                 UserRole
  status               UserStatus
  passwordHash         String
  lastSeenAt           DateTime
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  subscriptions        Subscription[]
  ownedTeams           Team[]              @relation("TeamOwner")
  teamMemberships      TeamMember[]
  trafficLedgerEntries TrafficLedger[]
  trafficSnapshots     TrafficSnapshot[]
}

model Plan {
  id             String         @id
  name           String
  scope          PlanScope      @default(personal)
  totalTrafficGb Float
  renewable      Boolean
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  subscriptions  Subscription[]
}

model Subscription {
  id                 String                   @id
  userId             String?
  teamId             String?
  planId             String
  totalTrafficGb     Float
  usedTrafficGb      Float
  remainingTrafficGb Float
  expireAt           DateTime
  state              SubscriptionState
  renewable          Boolean
  sourceAction       SubscriptionSourceAction @default(created)
  lastSyncedAt       DateTime
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  plan               Plan                     @relation(fields: [planId], references: [id], onDelete: Cascade)
  user               User?                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  team               Team?                    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  trafficLedgerEntries TrafficLedger[]
  trafficSnapshots   TrafficSnapshot[]
  nodeAccesses       SubscriptionNodeAccess[]
}

model Team {
  id            String         @id
  name          String
  ownerUserId   String
  status        TeamStatus
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  owner         User           @relation("TeamOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  members       TeamMember[]
  subscriptions Subscription[]
  trafficLedgerEntries TrafficLedger[]
  trafficSnapshots TrafficSnapshot[]
}

model TeamMember {
  id        String         @id
  teamId    String
  userId    String
  role      TeamMemberRole
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  team      Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@unique([userId])
}

model TrafficLedger {
  id             String       @id
  teamId         String
  userId         String
  subscriptionId String
  usedTrafficGb  Float
  recordedAt     DateTime
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  team           Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

model Node {
  id               String          @id
  name             String
  region           String
  provider         String
  tags             String[]
  recommended      Boolean
  latencyMs        Int
  protocol         String
  security         String
  serverHost       String
  serverPort       Int
  uuid             String
  flow             String
  realityPublicKey String
  shortId          String
  serverName       String
  fingerprint      String
  spiderX          String          @default("/")
  subscriptionUrl  String?
  statsEnabled     Boolean         @default(false)
  statsApiUrl      String?
  statsApiToken    String?
  statsLastSyncedAt DateTime?
  probeStatus      NodeProbeStatus @default(unknown)
  probeLatencyMs   Int?
  probeCheckedAt   DateTime?
  probeError       String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  subscriptionAccesses SubscriptionNodeAccess[]
  trafficSnapshots TrafficSnapshot[]
}

model SubscriptionNodeAccess {
  id             String       @id
  subscriptionId String
  nodeId         String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  node           Node         @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, nodeId])
}

model TrafficSnapshot {
  id               String       @id
  snapshotKey      String       @unique
  nodeId           String
  subscriptionId   String
  userId           String?
  teamId           String?
  uplinkBytes      BigInt       @default(0)
  downlinkBytes    BigInt       @default(0)
  totalBytes       BigInt       @default(0)
  sampledAt        DateTime
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  node             Node         @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  subscription     Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  user             User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  team             Team?        @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([nodeId, subscriptionId])
}

model PolicyProfile {
  id              String          @id
  defaultMode     String
  modes           String[]
  ruleVersion     String
  ruleUpdatedAt   DateTime
  dnsProfile      String
  blockAds        Boolean
  chinaDirect     Boolean
  aiServicesProxy Boolean
  currentVersion  String
  minimumVersion  String
  forceUpgrade    Boolean         @default(false)
  changelog       String[]
  downloadUrl     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  strategyGroups  StrategyGroup[]
}

model StrategyGroup {
  id            String        @id
  policyId      String
  name          String
  description   String
  defaultNodeId String
  policy        PolicyProfile @relation(fields: [policyId], references: [id], onDelete: Cascade)
}

model Announcement {
  id              String                  @id
  title           String
  body            String
  level           AnnouncementLevel
  publishedAt     DateTime
  isActive        Boolean                 @default(true)
  displayMode     AnnouncementDisplayMode @default(passive)
  countdownSeconds Int                    @default(0)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
}
